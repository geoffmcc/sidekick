#!/usr/bin/env node

/**
 * Git credential helper for Sidekick
 * Reads GitHub token from sidekick_secret encrypted store
 * 
 * Usage: git config credential.helper /path/to/git-credential-sidekick
 */

const fs = require('fs');
const path = require('path');
const crypto = require('crypto');

// Parse git credential request from stdin
function parseRequest(input) {
  const lines = input.trim().split('\n');
  const request = {};
  for (const line of lines) {
    const [key, ...valueParts] = line.split('=');
    if (key && valueParts.length > 0) {
      request[key] = valueParts.join('=');
    }
  }
  return request;
}

// Load environment variables from .env file
function loadEnv(envPath) {
  const env = {};
  if (!fs.existsSync(envPath)) return env;
  
  const content = fs.readFileSync(envPath, 'utf8');
  for (const line of content.split('\n')) {
    const trimmed = line.trim();
    if (!trimmed || trimmed.startsWith('#')) continue;
    
    const eqIndex = trimmed.indexOf('=');
    if (eqIndex === -1) continue;
    
    const key = trimmed.substring(0, eqIndex).trim();
    const value = trimmed.substring(eqIndex + 1).trim();
    env[key] = value;
  }
  return env;
}

// Decrypt a secret from secrets.enc
function decryptSecret(secretsPath, secretKey, encryptionKey) {
  if (!fs.existsSync(secretsPath)) {
    throw new Error(`Secrets file not found: ${secretsPath}`);
  }
  
  const secrets = JSON.parse(fs.readFileSync(secretsPath, 'utf8'));
  const entry = secrets[secretKey];
  
  if (!entry) {
    throw new Error(`Secret not found: ${secretKey}`);
  }
  
  // Derive AES key from SIDEKICK_SECRET_KEY using SHA-256
  const key = crypto.createHash('sha256').update(encryptionKey).digest();
  
  // Decrypt using AES-256-GCM
  const iv = Buffer.from(entry.iv, 'hex');
  const authTag = Buffer.from(entry.authTag, 'hex');
  const encryptedData = Buffer.from(entry.data, 'hex');
  
  const decipher = crypto.createDecipheriv('aes-256-gcm', key, iv);
  decipher.setAuthTag(authTag);
  
  let decrypted = decipher.update(encryptedData);
  decrypted = Buffer.concat([decrypted, decipher.final()]);
  
  return decrypted.toString('utf8');
}

// Main
async function main() {
  let input = '';
  
  // Read from stdin
  process.stdin.setEncoding('utf8');
  for await (const chunk of process.stdin) {
    input += chunk;
  }
  
  const request = parseRequest(input);
  
  // Only handle 'get' operation
  if (request.action !== 'get') {
    process.exit(0);
  }
  
  // Only handle github.com
  if (request.host !== 'github.com') {
    process.exit(0);
  }
  
  // Find the sidekick project directory
  const scriptDir = __dirname;
  const projectDir = path.resolve(scriptDir, '..');
  const envPath = path.join(projectDir, '.env');
  const secretsPath = path.join(projectDir, 'data', 'secrets.enc');
  
  // Load environment
  const env = loadEnv(envPath);
  const secretKey = env.SIDEKICK_SECRET_KEY;
  
  if (!secretKey) {
    console.error('SIDEKICK_SECRET_KEY not found in .env');
    process.exit(1);
  }
  
  try {
    // Decrypt the GitHub token
    const token = decryptSecret(secretsPath, 'github_token', secretKey);
    
    // Output in git credential format
    console.log('protocol=https');
    console.log('host=github.com');
    console.log('username=geoffmcc');
    console.log(`password=${token}`);
  } catch (error) {
    console.error(`Failed to decrypt GitHub token: ${error.message}`);
    process.exit(1);
  }
}

main().catch(error => {
  console.error(`Error: ${error.message}`);
  process.exit(1);
});
