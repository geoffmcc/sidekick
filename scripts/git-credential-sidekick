#!/usr/bin/env node

/**
 * Git credential helper for Sidekick
 * Reads GitHub token from KV store
 * 
 * Usage: git config credential.helper /path/to/git-credential-sidekick
 */

const fs = require('fs');
const path = require('path');
const Database = require('better-sqlite3');

// Parse git credential request from stdin
function parseRequest(input) {
  const lines = input.trim().split('\n');
  const request = {};
  for (const line of lines) {
    const [key, ...valueParts] = line.split('=');
    if (key && valueParts.length > 0) {
      request[key] = valueParts.join('=');
    }
  }
  return request;
}

// Main
async function main() {
  let input = '';
  
  // Read from stdin
  process.stdin.setEncoding('utf8');
  for await (const chunk of process.stdin) {
    input += chunk;
  }
  
  const request = parseRequest(input);
  
  // Only handle github.com
  if (request.host !== 'github.com') {
    process.exit(0);
  }
  
  // Find the sidekick project directory
  const scriptDir = __dirname;
  const projectDir = path.resolve(scriptDir, '..');
  const dbPath = path.join(projectDir, 'data', 'sidekick.db');
  
  // Open database
  const db = new Database(dbPath, { readonly: true });
  
  try {
    // Get github_token from KV store
    const row = db.prepare('SELECT value_json FROM kv_store WHERE key = ?').get('github_token');
    
    if (!row) {
      console.error('github_token not found in KV store');
      process.exit(1);
    }
    
    // Parse JSON and extract value
    const entry = JSON.parse(row.value_json);
    const token = entry.value;
    
    // Output in git credential format
    console.log('protocol=https');
    console.log('host=github.com');
    console.log('username=geoffmcc');
    console.log(`password=${token}`);
  } catch (error) {
    console.error(`Failed to read GitHub token: ${error.message}`);
    process.exit(1);
  } finally {
    db.close();
  }
}

main().catch(error => {
  console.error(`Error: ${error.message}`);
  process.exit(1);
});
