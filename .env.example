# API key for MCP server authentication (used by opencode and agent bridge)
SIDEKICK_API_KEY=sk-your-key-here

# IP whitelist for MCP server (comma-separated, 127.0.0.1/::1 always allowed)
SIDEKICK_ALLOWED_IPS=

# IP whitelist for dashboard (comma-separated, 127.0.0.1/::1 always allowed)
SIDEKICK_DASHBOARD_ALLOWED_IPS=

# Ports for the three services
SIDEKICK_PORT=4097
SIDEKICK_DASHBOARD_PORT=4098
SIDEKICK_AGENT_PORT=4099

# Dashboard authentication (leave empty for no auth)
SIDEKICK_DASHBOARD_USER=
SIDEKICK_DASHBOARD_PASS=

# Directory for logs, KV store, and conversation transcripts
SIDEKICK_DATA_DIR=/home/sidekick/sidekick/data

# SQLite database file (default: SIDEKICK_DATA_DIR/sidekick.db)
SIDEKICK_DB_FILE=

# Directory for database backups (default: data/backups)
SIDEKICK_BACKUP_DIR=

# Directory for schema migrations (default: migrations in repo root)
SIDEKICK_MIGRATIONS_DIR=

# Maximum retained tool log rows
SIDEKICK_MAX_LOG=1000

# Ollama API (local fallback, only used when GROQ_API_KEY is empty)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Default LLM provider for sidekick_llm: ollama or groq
SIDEKICK_DEFAULT_LLM=ollama

# Groq cloud LLM (leave empty to use local Ollama)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Required by sidekick_secret encrypted credential storage
SIDEKICK_SECRET_KEY=

# Max agent loop iterations (safety limit, dedup safeguard prevents runaway loops)
SIDEKICK_MAX_ITERATIONS=15
