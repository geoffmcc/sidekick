# API key for MCP server authentication (used by opencode and agent bridge)
SIDEKICK_API_KEY=sk-your-key-here

# IP whitelist for MCP server (comma-separated, 127.0.0.1/::1 always allowed)
SIDEKICK_ALLOWED_IPS=

# IP whitelist for dashboard (comma-separated, 127.0.0.1/::1 always allowed)
# Leave empty to disable (dashboard still protected by HTTP Basic Auth above)
SIDEKICK_DASHBOARD_ALLOWED_IPS=

# Ports for the three services
SIDEKICK_PORT=4097
SIDEKICK_DASHBOARD_PORT=4098
SIDEKICK_AGENT_PORT=4099

# Dashboard authentication (leave empty for no auth; required if dashboard is reachable beyond localhost)
SIDEKICK_DASHBOARD_USER=
SIDEKICK_DASHBOARD_PASS=

# Directory for logs, KV store, and conversation transcripts
SIDEKICK_DATA_DIR=/home/sidekick/sidekick/data

# SQLite database file (default: SIDEKICK_DATA_DIR/sidekick.db)
SIDEKICK_DB_FILE=

# Directory for database backups (default: data/backups)
SIDEKICK_BACKUP_DIR=

# Directory for schema migrations (default: migrations in repo root)
SIDEKICK_MIGRATIONS_DIR=

# Maximum retained tool log rows
SIDEKICK_MAX_LOG=1000

# Automatic memory summaries for useful tool calls and completed Agent Bridge tasks
# Set to 0/false/off to disable
SIDEKICK_AUTO_MEMORY=1
SIDEKICK_AUTO_MEMORY_MAX=500
SIDEKICK_EMBEDDINGS=1
SIDEKICK_EMBEDDING_MODEL=nomic-embed-text
SIDEKICK_OLLAMA_URL=http://127.0.0.1:11434

# Ollama API (local fallback, only used when GROQ_API_KEY is empty)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Default LLM provider for sidekick_llm: ollama or groq
SIDEKICK_DEFAULT_LLM=ollama

# Groq cloud LLM (leave empty to use local Ollama)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Required by sidekick_secret encrypted credential storage
SIDEKICK_SECRET_KEY=

# PostgreSQL connection (for sidekick_db_* tools with database='postgres')
# Default: postgresql://sidekick:sidekick@127.0.0.1:5432/sidekick
SIDEKICK_POSTGRES_URL=

# Redis connection (for sidekick_redis tool)
# Default: redis://127.0.0.1:6379
SIDEKICK_REDIS_URL=

# Max agent loop iterations (safety limit, dedup safeguard prevents runaway loops)
SIDEKICK_MAX_ITERATIONS=15

# Evolve tool retention (days to keep rejected/test_failed proposals before cleanup)
# Approved proposals are kept forever. Auto-cleanup triggers when file > 100KB or > 50 proposals.
SIDEKICK_EVOLVE_RETENTION_DAYS=30

# Tool permission policy:
# - open: all tools are allowed unless blocked below (default/backward compatible)
# - restricted: high/critical risk tools are blocked unless explicitly allowed
SIDEKICK_TOOL_POLICY=open

# Comma-separated tool policy overrides. Entries can be tool names or risk:high/risk:critical.
# Global examples:
# SIDEKICK_BLOCKED_TOOLS=sidekick_db_restore,sidekick_evolve
# SIDEKICK_ALLOWED_TOOLS=sidekick_read,sidekick_search,sidekick_get,risk:low
SIDEKICK_BLOCKED_TOOLS=
SIDEKICK_ALLOWED_TOOLS=

# Source-specific overrides for mcp, dashboard, and agent sources.
# SIDEKICK_AGENT_TOOL_POLICY=restricted
# SIDEKICK_AGENT_ALLOWED_TOOLS=sidekick_read,sidekick_search,sidekick_get,sidekick_respond
# Inspect effective policy with: sidekick_tools({ action: "policy", source: "mcp,dashboard,agent" })
SIDEKICK_MCP_TOOL_POLICY=
SIDEKICK_MCP_BLOCKED_TOOLS=
SIDEKICK_MCP_ALLOWED_TOOLS=
SIDEKICK_DASHBOARD_TOOL_POLICY=
SIDEKICK_DASHBOARD_BLOCKED_TOOLS=
SIDEKICK_DASHBOARD_ALLOWED_TOOLS=
SIDEKICK_AGENT_TOOL_POLICY=
SIDEKICK_AGENT_BLOCKED_TOOLS=
SIDEKICK_AGENT_ALLOWED_TOOLS=

# Optional approval queue. Default off preserves existing behavior.
# Modes:
# - off: allowed tools execute immediately
# - risky: critical risk tools require dashboard approval unless exempted
# - strict: high/critical risk tools require dashboard approval unless exempted
# Entries can be tool names or risk:high/risk:critical.
SIDEKICK_APPROVAL_MODE=off
SIDEKICK_APPROVAL_REQUIRED_TOOLS=
SIDEKICK_APPROVAL_EXEMPT_TOOLS=
SIDEKICK_MCP_APPROVAL_MODE=
SIDEKICK_MCP_APPROVAL_REQUIRED_TOOLS=
SIDEKICK_MCP_APPROVAL_EXEMPT_TOOLS=
SIDEKICK_DASHBOARD_APPROVAL_MODE=
SIDEKICK_DASHBOARD_APPROVAL_REQUIRED_TOOLS=
SIDEKICK_DASHBOARD_APPROVAL_EXEMPT_TOOLS=
SIDEKICK_AGENT_APPROVAL_MODE=
SIDEKICK_AGENT_APPROVAL_REQUIRED_TOOLS=
SIDEKICK_AGENT_APPROVAL_EXEMPT_TOOLS=
