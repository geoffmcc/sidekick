# API key for MCP server authentication (used by opencode and agent bridge)
SIDEKICK_API_KEY=sk-your-key-here

# Ports for the three services
SIDEKICK_PORT=4097
SIDEKICK_DASHBOARD_PORT=4098
SIDEKICK_AGENT_PORT=4099

# Directory for logs, KV store, and conversation transcripts
SIDEKICK_DATA_DIR=/home/sidekick/mcp-sidekick/data

# Ollama API (local, not exposed externally)
OLLAMA_URL=http://127.0.0.1:11434
